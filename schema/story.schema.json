{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Story",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "const": "1",
      "description": "Story JSON format; must match STORY_JSON_VERSION in exportStory.ts"
    },
    "waypoints": {
      "type": "array",
      "items": { "$ref": "#/definitions/Waypoint" }
    },
    "shapes": {
      "type": "array",
      "description": "Global registry; waypoints reference entries by uuid via shapes[]",
      "items": { "$ref": "#/definitions/Shape" }
    }
  },
  "required": ["version", "waypoints", "shapes"],
  "definitions": {
    "StoryPoint": {
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      },
      "required": ["x", "y"]
    },
    "Shape": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": { "const": "point" },
            "uuid": { "type": "string" },
            "point": { "$ref": "#/definitions/StoryPoint" }
          },
          "required": ["type", "uuid", "point"]
        },
        {
          "type": "object",
          "properties": {
            "type": { "const": "arrow" },
            "point": {
              "$ref": "#/definitions/StoryPoint",
              "description": "Arrow tip (image pixels)"
            },
            "angle": {
              "type": "number",
              "description": "Radians: bearing from tip toward tail (+x = 0, CCW in image pixel space)."
            },
            "label": {
              "type": "string",
              "description": "Caption toward the arrow tail (same role as LineAnnotation.text)"
            },
            "uuid": { "type": "string" }
          },
          "required": ["type", "point", "angle", "uuid"]
        },
        {
          "type": "object",
          "properties": {
            "type": { "const": "polygon" },
            "uuid": { "type": "string" },
            "points": {
              "type": "array",
              "items": { "$ref": "#/definitions/StoryPoint" }
            }
          },
          "required": ["type", "uuid", "points"]
        },
        {
          "type": "object",
          "properties": {
            "type": { "const": "polyline" },
            "uuid": { "type": "string" },
            "points": {
              "type": "array",
              "items": { "$ref": "#/definitions/StoryPoint" }
            }
          },
          "required": ["type", "uuid", "points"]
        },
        {
          "type": "object",
          "properties": {
            "type": { "const": "text" },
            "uuid": { "type": "string" },
            "content": { "type": "string" },
            "point": { "$ref": "#/definitions/StoryPoint" }
          },
          "required": ["type", "uuid", "content", "point"]
        }
      ]
    },
    "Waypoint": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "UUID" },
        "title": {
          "type": "string",
          "description": "Display title (maps to internal Name)"
        },
        "name": {
          "type": "string",
          "description": "Legacy alias for title"
        },
        "content": {
          "type": "string",
          "description": "Markdown narrative text"
        },
        "group": {
          "type": "string",
          "description": "Channel group key (optional; app may use name or uuid string)"
        },
        "thumbnail": {
          "type": "string",
          "description": "Optional image data URL for list previews (typically JPEG, 64×64 pixels)"
        },
        "viewport": { "$ref": "#/definitions/Viewport" },
        "shapes": {
          "type": "array",
          "description": "UUIDs of shapes used on this waypoint (see root shapes[])",
          "items": { "type": "string" }
        }
      },
      "allOf": [
        {
          "required": ["id", "content", "viewport", "shapes"]
        },
        {
          "anyOf": [{ "required": ["title"] }, { "required": ["name"] }]
        }
      ]
    },
    "Viewport": {
      "description": "Visible image region in pixel coordinates (upperLeft / lowerRight corners)",
      "type": "object",
      "properties": {
        "upperLeft": { "$ref": "#/definitions/StoryPoint" },
        "lowerRight": { "$ref": "#/definitions/StoryPoint" }
      },
      "required": ["upperLeft", "lowerRight"]
    }
  }
}

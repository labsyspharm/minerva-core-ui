{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Story",
  "type": "object",
  "properties": {
    "version": { "type": "string", "const": "2" },
    "waypoints": {
      "type": "array",
      "items": { "$ref": "#/definitions/Waypoint" }
    },
    "shapes": {
      "type": "array",
      "description": "Global registry; waypoints reference entries by uuid via shapes[]",
      "items": { "$ref": "#/definitions/Shape" }
    }
  },
  "required": ["version", "waypoints", "shapes"],
  "definitions": {
    "StoryPoint": {
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      },
      "required": ["x", "y"]
    },
    "Shape": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": { "const": "point" },
            "uuid": { "type": "string" },
            "point": { "$ref": "#/definitions/StoryPoint" }
          },
          "required": ["type", "uuid", "point"]
        },
        {
          "type": "object",
          "properties": {
            "type": { "const": "arrow" },
            "uuid": { "type": "string" },
            "point": {
              "$ref": "#/definitions/StoryPoint",
              "description": "Arrow tip (image pixels)"
            },
            "angle": {
              "type": "number",
              "description": "Degrees: bearing from tip toward tail (matches legacy waypoint arrow Angle)"
            },
            "label": {
              "type": "string",
              "description": "Caption toward the arrow tail (same role as LineAnnotation.text)"
            }
          },
          "required": ["type", "uuid", "point", "angle"]
        },
        {
          "type": "object",
          "properties": {
            "type": { "const": "polygon" },
            "uuid": { "type": "string" },
            "points": {
              "type": "array",
              "items": { "$ref": "#/definitions/StoryPoint" }
            }
          },
          "required": ["type", "uuid", "points"]
        },
        {
          "type": "object",
          "properties": {
            "type": { "const": "polyline" },
            "uuid": { "type": "string" },
            "points": {
              "type": "array",
              "items": { "$ref": "#/definitions/StoryPoint" }
            }
          },
          "required": ["type", "uuid", "points"]
        },
        {
          "type": "object",
          "properties": {
            "type": { "const": "text" },
            "uuid": { "type": "string" },
            "content": { "type": "string" },
            "point": { "$ref": "#/definitions/StoryPoint" }
          },
          "required": ["type", "uuid", "content", "point"]
        }
      ]
    },
    "Waypoint": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "UUID" },
        "name": { "type": "string" },
        "content": {
          "type": "string",
          "description": "Markdown narrative text"
        },
        "group": {
          "type": "string",
          "description": "Channel group name (optional)"
        },
        "position": { "$ref": "#/definitions/Position" },
        "shapes": {
          "type": "array",
          "description": "UUIDs of shapes used on this waypoint (see root shapes[])",
          "items": { "type": "string" }
        }
      },
      "required": ["id", "name", "content", "position", "shapes"]
    },
    "Position": {
      "description": "Viewport position in image pixel coordinates",
      "type": "object",
      "properties": {
        "x": {
          "type": "number",
          "description": "Image pixel x of viewport center"
        },
        "y": {
          "type": "number",
          "description": "Image pixel y of viewport center"
        },
        "zoom": {
          "type": "number",
          "description": "deck.gl log2 zoom (0 = 1:1 pixel, negative = zoomed out)"
        }
      },
      "required": ["x", "y", "zoom"]
    }
  }
}

    "styled-components": "^6.1.12",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-json-schema": "^0.64.0",
    "vite": "^5.3.4",
    "vite-plugin-mkcert": "^1.17.5",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^3.2.7",
    "http-server": "^14.1.1"

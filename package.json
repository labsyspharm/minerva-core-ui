    "@luma.gl/webgl": "9.1.9",
    "@math.gl/core": "^4.1.0",
    "@math.gl/web-mercator": "^4.1.0",
    "@tanstack/react-router": "^1.168.21",
    "@types/wicg-file-system-access": "^2023.10.5",
    "@uiw/react-color": "^2.9.6",
    "@uiw/react-md-editor": "^4.0.11",
    "@vivjs/constants": "0.20.1",
    "browser-fs-access": "^0.38.0",
    "dcmjs": "^0.41.0",

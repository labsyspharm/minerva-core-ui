    "react-markdown": "^10.1.0",
    "stable-hash": "^0.0.6",
    "vite-plugin-svgr": "^4.3.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@babel/core": "^7.24.9",
    "@biomejs/biome": "2.3.14",
    "@types/node": "^20.14.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "@vitejs/plugin-react": "^4.3.1",
    "@vivjs/types": "0.20.1",
    "eslint": "^9.7.0",
